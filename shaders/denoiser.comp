#version 450
#extension GL_GOOGLE_include_directive : require

#include "temporal_common.glsl"

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

#ifndef RTV_DENOISER_SHARED_TILE
#define RTV_DENOISER_SHARED_TILE 1
#endif

layout(set = 0, binding = 0, rgba16f) readonly uniform image2D input_color;
layout(set = 0, binding = 1, std430) readonly buffer InputDepthNormal { uvec4 input_depth_normal[]; };
layout(set = 0, binding = 2, std430) readonly buffer InputVariance { uint input_variance[]; };
layout(set = 0, binding = 3, rgba16f) readonly uniform image2D history_color;
layout(set = 0, binding = 4, rgba16f) writeonly uniform image2D output_denoised;

layout(set = 0, binding = 5, std140) uniform DenoiserParams {
    uint enabled;
    float strength;
    uint frame_count;
    uint width;
    uint height;
    uint atrous_iterations;
    uint debug_view;
    uint reset_history;
} params;

layout(set = 0, binding = 6, std430) readonly buffer WorldPosition { uvec2 world_position[]; };
layout(set = 0, binding = 7, std430) readonly buffer PrevWorldPosition { uvec2 prev_world_position[]; };
layout(set = 0, binding = 9, std430) readonly buffer VelocityBuffer { uint velocity_buffer[]; };
struct PathDataRecord {
    vec4 direct_diffuse;
    vec4 direct_specular;
    vec4 indirect_diffuse;
    vec4 indirect_specular;
    vec4 albedo_roughness_hit_confidence;
};
layout(set = 0, binding = 10, std430) readonly buffer PathDataBuffer { PathDataRecord path_data_buffer[]; };

layout(set = 0, binding = 8, std140) uniform PrevCamera {
    mat4 view_proj;
    mat4 inv_view_proj;
    mat4 prev_view_proj;
    vec4 current_pos;
    vec4 prev_pos;
    vec4 jitter;
} prev_camera;

float luminance(vec3 c) {
    return dot(c, vec3(0.2126, 0.7152, 0.0722));
}

#if RTV_DENOISER_SHARED_TILE
const int DENOISER_TILE_RADIUS = 2;
const int DENOISER_LOCAL_SIZE_X = 16;
const int DENOISER_LOCAL_SIZE_Y = 16;
const int DENOISER_SHARED_SIZE_X = DENOISER_LOCAL_SIZE_X + DENOISER_TILE_RADIUS * 2;
const int DENOISER_SHARED_SIZE_Y = DENOISER_LOCAL_SIZE_Y + DENOISER_TILE_RADIUS * 2;
const int DENOISER_SHARED_COUNT = DENOISER_SHARED_SIZE_X * DENOISER_SHARED_SIZE_Y;

shared vec4 shared_color_tile[DENOISER_SHARED_COUNT];
shared uvec4 shared_depth_normal_tile[DENOISER_SHARED_COUNT];

int denoiser_shared_index(ivec2 tileCoords) {
    return tileCoords.y * DENOISER_SHARED_SIZE_X + tileCoords.x;
}
#endif

float atrous_kernel_weight(int offsetValue) {
    if (offsetValue == 0) {
        return 0.375;
    }
    if (abs(offsetValue) == 1) {
        return 0.25;
    }
    return 0.0625;
}

bool is_surface_depth(float depth) {
    return depth < 1.0e9;
}

vec2 unpack_unorm2x16(uint packedValue) {
    return vec2(float(packedValue & 0xffffu), float((packedValue >> 16u) & 0xffffu)) / 65535.0;
}

vec2 unpack_snorm2x16(uint packedValue) {
    return unpack_unorm2x16(packedValue) * 2.0 - vec2(1.0);
}

uint pack_snorm2x16(vec2 value) {
    vec2 v = clamp(value, vec2(-1.0), vec2(1.0)) * 0.5 + vec2(0.5);
    uvec2 packedValue = uvec2(round(v * 65535.0));
    return (packedValue.y << 16u) | packedValue.x;
}

vec3 decode_octahedral_normal(uint packedValue) {
    vec2 f = unpack_snorm2x16(packedValue);
    vec3 n = vec3(f.x, f.y, 1.0 - abs(f.x) - abs(f.y));
    float t = clamp(-n.z, 0.0, 1.0);
    n.x += n.x >= 0.0 ? -t : t;
    n.y += n.y >= 0.0 ? -t : t;
    return normalize(n);
}

vec4 decode_depth_normal(uvec4 packedValue) {
    return vec4(uintBitsToFloat(packedValue.x), decode_octahedral_normal(packedValue.y));
}

float decode_variance(uint packedValue) {
    return float(packedValue & 0xffffu) / 65535.0 * 64.0;
}

vec3 decode_world_position(uvec2 packedValue, vec3 origin) {
    if (packedValue.x == 0u && packedValue.y == 0u) {
        return vec3(0.0, 1.0e10, 0.0);
    }
    vec2 xy = unpack_snorm2x16(packedValue.x);
    float z = unpack_snorm2x16(packedValue.y).x;
    return origin + vec3(xy.x, xy.y, z) * 8.0;
}

vec3 reconstruct_current_world_position(ivec2 coords, float depth, ivec2 dims) {
    if (!is_surface_depth(depth)) {
        return vec3(0.0, 1.0e10, 0.0);
    }

    vec2 uv = (vec2(coords) + vec2(0.5)) / vec2(dims);
    vec2 ndc = uv * 2.0 - 1.0;
    vec4 world_far = prev_camera.inv_view_proj * vec4(ndc, 1.0, 1.0);
    if (abs(world_far.w) <= 1.0e-6) {
        return decode_world_position(world_position[uint(coords.y) * uint(dims.x) + uint(coords.x)], prev_camera.current_pos.xyz);
    }

    vec3 ray_dir = world_far.xyz / world_far.w - prev_camera.current_pos.xyz;
    if (dot(ray_dir, ray_dir) <= 1.0e-8) {
        return decode_world_position(world_position[uint(coords.y) * uint(dims.x) + uint(coords.x)], prev_camera.current_pos.xyz);
    }

    return prev_camera.current_pos.xyz + normalize(ray_dir) * depth;
}

vec2 project_world_to_pixels(mat4 viewProj, vec3 worldPos, ivec2 dims) {
    vec4 clip = viewProj * vec4(worldPos, 1.0);
    if (clip.w <= 0.0) {
        return vec2(-1.0);
    }
    vec3 ndc = clip.xyz / clip.w;
    if (ndc.z < 0.0 || ndc.z > 1.0001) {
        return vec2(-1.0);
    }
    return vec2(
        (ndc.x * 0.5 + 0.5) * float(dims.x) - 0.5,
        (ndc.y * 0.5 + 0.5) * float(dims.y) - 0.5);
}

vec2 project_world_to_history(vec3 worldPos, ivec2 dims) {
    return project_world_to_pixels(prev_camera.prev_view_proj, worldPos, dims);
}

vec2 reproject_history(ivec2 coords, vec3 worldPos, ivec2 dims) {
    return project_world_to_history(worldPos, dims);
}

vec2 reproject_sky_history(ivec2 coords, ivec2 dims) {
    vec2 uv = (vec2(coords) + vec2(0.5)) / vec2(dims);
    vec2 ndc = uv * 2.0 - 1.0;
    vec4 world_far = prev_camera.inv_view_proj * vec4(ndc, 1.0, 1.0);
    if (abs(world_far.w) <= 1.0e-6) {
        return vec2(-1.0);
    }

    vec3 current_far = world_far.xyz / world_far.w;
    vec3 sky_dir = current_far - prev_camera.current_pos.xyz;
    if (dot(sky_dir, sky_dir) <= 1.0e-8) {
        return vec2(-1.0);
    }

    return project_world_to_history(prev_camera.prev_pos.xyz + normalize(sky_dir) * 512.0, dims);
}

vec3 bilinear_history_color(vec2 historyPos, ivec2 dims) {
    ivec2 base = ivec2(floor(historyPos));
    vec2 fracValue = fract(historyPos);
    ivec2 p00 = clamp(base, ivec2(0), dims - ivec2(1));
    ivec2 p10 = clamp(base + ivec2(1, 0), ivec2(0), dims - ivec2(1));
    ivec2 p01 = clamp(base + ivec2(0, 1), ivec2(0), dims - ivec2(1));
    ivec2 p11 = clamp(base + ivec2(1, 1), ivec2(0), dims - ivec2(1));
    vec3 c00 = imageLoad(history_color, p00).rgb;
    vec3 c10 = imageLoad(history_color, p10).rgb;
    vec3 c01 = imageLoad(history_color, p01).rgb;
    vec3 c11 = imageLoad(history_color, p11).rgb;
    return mix(mix(c00, c10, fracValue.x), mix(c01, c11, fracValue.x), fracValue.y);
}

vec3 bilinear_prev_world(vec2 historyPos, ivec2 dims) {
    ivec2 base = ivec2(floor(historyPos));
    vec2 fracValue = fract(historyPos);
    ivec2 p00 = clamp(base, ivec2(0), dims - ivec2(1));
    ivec2 p10 = clamp(base + ivec2(1, 0), ivec2(0), dims - ivec2(1));
    ivec2 p01 = clamp(base + ivec2(0, 1), ivec2(0), dims - ivec2(1));
    ivec2 p11 = clamp(base + ivec2(1, 1), ivec2(0), dims - ivec2(1));
    uint i00 = uint(p00.y) * uint(dims.x) + uint(p00.x);
    uint i10 = uint(p10.y) * uint(dims.x) + uint(p10.x);
    uint i01 = uint(p01.y) * uint(dims.x) + uint(p01.x);
    uint i11 = uint(p11.y) * uint(dims.x) + uint(p11.x);
    vec3 w00 = decode_world_position(prev_world_position[i00], prev_camera.prev_pos.xyz);
    vec3 w10 = decode_world_position(prev_world_position[i10], prev_camera.prev_pos.xyz);
    vec3 w01 = decode_world_position(prev_world_position[i01], prev_camera.prev_pos.xyz);
    vec3 w11 = decode_world_position(prev_world_position[i11], prev_camera.prev_pos.xyz);
    return mix(mix(w00, w10, fracValue.x), mix(w01, w11, fracValue.x), fracValue.y);
}

void main() {
    ivec2 coords = ivec2(gl_GlobalInvocationID.xy);
    ivec2 dims = imageSize(input_color);
    bool in_bounds = coords.x < dims.x && coords.y < dims.y;

#if RTV_DENOISER_SHARED_TILE
    ivec2 workgroup_origin = ivec2(gl_WorkGroupID.xy) * ivec2(DENOISER_LOCAL_SIZE_X, DENOISER_LOCAL_SIZE_Y);
    uint local_linear = gl_LocalInvocationID.y * gl_WorkGroupSize.x + gl_LocalInvocationID.x;
    uint local_count = gl_WorkGroupSize.x * gl_WorkGroupSize.y;
    ivec2 max_coords = max(dims - ivec2(1), ivec2(0));
    for (uint i = local_linear; i < uint(DENOISER_SHARED_COUNT); i += local_count) {
        ivec2 tile_coords = ivec2(int(i) % DENOISER_SHARED_SIZE_X, int(i) / DENOISER_SHARED_SIZE_X);
        ivec2 sample_coords = clamp(workgroup_origin + tile_coords - ivec2(DENOISER_TILE_RADIUS), ivec2(0), max_coords);
        uint sample_index = uint(sample_coords.y) * uint(dims.x) + uint(sample_coords.x);
        shared_color_tile[i] = imageLoad(input_color, sample_coords);
        shared_depth_normal_tile[i] = input_depth_normal[sample_index];
    }
    barrier();
#endif

    if (!in_bounds) {
        return;
    }

    vec3 center_color = imageLoad(input_color, coords).rgb;
    uint pixel_index = uint(coords.y) * uint(dims.x) + uint(coords.x);
    vec4 center_dn = decode_depth_normal(input_depth_normal[pixel_index]);
    float center_depth = center_dn.r;
    vec3 center_normal = center_dn.gba;
    float center_roughness = clamp(uintBitsToFloat(input_depth_normal[pixel_index].z), 0.0, 1.0);
    float center_var = decode_variance(input_variance[pixel_index]);

    if (params.enabled == 0u && params.debug_view == 0u) {
        imageStore(output_denoised, coords, vec4(center_color, 1.0));
        return;
    }

    float center_lum = luminance(center_color);
    float var_factor = sqrt(max(center_var, 0.0));
    float inv_strength = 1.0 / max(params.strength, 0.001);
    float sigma_color = (0.18 + var_factor * 1.8) * inv_strength;
    float sigma_depth = (0.12 + var_factor * 0.45) * inv_strength;
    float sigma_normal = 0.42 * inv_strength;
    int adaptive_kernel_radius = int(clamp(ceil(mix(1.0, 2.0, max(center_roughness, clamp(center_var / 4.0, 0.0, 1.0)))), 1.0, 2.0));
    uint iterations = clamp(params.atrous_iterations, 1u, 5u);

    vec3 filtered_color = center_color;
    vec3 scale_accumulated_color = vec3(0.0);
    float scale_accumulated_weight = 0.0;
    vec3 min_color = vec3(1.0e10);
    vec3 max_color = vec3(-1.0e10);
    float lum_sum = 0.0;
    float lum_sq_sum = 0.0;
    float neighborhood_count = 0.0;
    float normal_cone_min = 1.0;
    float max_relative_depth_delta = 0.0;

    for (uint iter = 0u; iter < 5u; ++iter) {
        if (iter >= iterations) {
            break;
        }
        int step_width = int(1u << iter);
        vec3 pass_color = vec3(0.0);
        float pass_weight = 0.0;

        for (int ky = -2; ky <= 2; ++ky) {
            for (int kx = -2; kx <= 2; ++kx) {
                if (abs(kx) > adaptive_kernel_radius || abs(ky) > adaptive_kernel_radius) {
                    continue;
                }
                ivec2 sample_coords = coords + ivec2(kx * step_width, ky * step_width);
                if (sample_coords.x < 0 || sample_coords.x >= dims.x || sample_coords.y < 0 || sample_coords.y >= dims.y) {
                    continue;
                }

#if RTV_DENOISER_SHARED_TILE
                vec3 sample_color;
                vec4 sample_dn;
                if (iter == 0u) {
                    ivec2 tile_coords = ivec2(gl_LocalInvocationID.xy) + ivec2(kx + DENOISER_TILE_RADIUS, ky + DENOISER_TILE_RADIUS);
                    int tile_index = denoiser_shared_index(tile_coords);
                    sample_color = shared_color_tile[tile_index].rgb;
                    sample_dn = decode_depth_normal(shared_depth_normal_tile[tile_index]);
                } else {
                    sample_color = imageLoad(input_color, sample_coords).rgb;
                    sample_dn = decode_depth_normal(input_depth_normal[uint(sample_coords.y) * uint(dims.x) + uint(sample_coords.x)]);
                }
#else
                vec3 sample_color = imageLoad(input_color, sample_coords).rgb;
                vec4 sample_dn = decode_depth_normal(input_depth_normal[uint(sample_coords.y) * uint(dims.x) + uint(sample_coords.x)]);
#endif
                float sample_depth = sample_dn.r;
                vec3 sample_normal = sample_dn.gba;
                float sample_lum = luminance(sample_color);

                float kernel_w = atrous_kernel_weight(kx) * atrous_kernel_weight(ky);
                float color_diff = abs(sample_lum - center_lum);
                float color_w = exp(-color_diff / (sigma_color * (1.0 + float(iter) * 0.35) + 0.001));
                float depth_diff = abs(sample_depth - center_depth) / max(center_depth, 0.01);
                float depth_w = center_depth < 50.0 ? exp(-depth_diff / (sigma_depth + 0.001)) : 1.0;
                float normal_diff = 1.0 - clamp(dot(sample_normal, center_normal), -1.0, 1.0);
                float normal_w = center_depth < 50.0 ? exp(-normal_diff / (sigma_normal + 0.001)) : 1.0;
                float weight = kernel_w * color_w * depth_w * normal_w;

                pass_color += sample_color * weight;
                pass_weight += weight;
                min_color = min(min_color, sample_color);
                max_color = max(max_color, sample_color);
                lum_sum += sample_lum;
                lum_sq_sum += sample_lum * sample_lum;
                neighborhood_count += 1.0;

                if (is_surface_depth(center_depth) && is_surface_depth(sample_depth)) {
                    float sample_normal_dot = clamp(dot(sample_normal, center_normal), -1.0, 1.0);
                    normal_cone_min = min(normal_cone_min, sample_normal_dot);
                    max_relative_depth_delta = max(max_relative_depth_delta, depth_diff);
                }
            }
        }

        if (pass_weight > 0.0) {
            vec3 scale_color = pass_color / pass_weight;
            float scale_weight = 1.0 / (1.0 + float(iter) * 0.45);
            scale_accumulated_color += scale_color * scale_weight;
            scale_accumulated_weight += scale_weight;
        }
    }

    if (scale_accumulated_weight > 0.0) {
        filtered_color = scale_accumulated_color / scale_accumulated_weight;
    }

    float lum_mean = lum_sum / max(neighborhood_count, 1.0);
    float lum_variance = max(lum_sq_sum / max(neighborhood_count, 1.0) - lum_mean * lum_mean, 0.0);
    float lum_sigma = sqrt(lum_variance);

    bool sky_valid = !is_surface_depth(center_depth);
    vec3 wp = reconstruct_current_world_position(coords, center_depth, dims);
    vec2 history_pos = sky_valid ? reproject_sky_history(coords, dims) : reproject_history(coords, wp, dims);
    vec2 velocity_pixels = temporal_unpack_velocity_pixels(velocity_buffer[pixel_index], 64.0);
    vec2 velocity_history_pos = temporal_reproject_pixel(coords, velocity_pixels);
    bool velocity_on_screen = temporal_history_pixel_valid(velocity_history_pos, dims, 0.0);
    if (velocity_on_screen) {
        history_pos = velocity_history_pos;
    }
    bool on_screen = params.reset_history == 0u && temporal_history_pixel_valid(history_pos, dims, 0.0);
    vec2 history_sample_pos = on_screen ? history_pos : vec2(coords);

    vec3 history = bilinear_history_color(history_sample_pos, dims);
    vec3 reprojected_wp = bilinear_prev_world(history_sample_pos, dims);
    float pos_diff = length(wp - reprojected_wp);
    float relative_pos_diff = pos_diff / max(center_depth, 0.25);
    bool previous_sky_valid = reprojected_wp.y > 9.0e9;
    bool world_valid = is_surface_depth(center_depth) && !previous_sky_valid;
    bool history_kind_valid = sky_valid ? previous_sky_valid : world_valid;
    float disocclusion_confidence = sky_valid
        ? (on_screen && history_kind_valid ? 1.0 : 0.0)
        : temporal_disocclusion_confidence(
            on_screen,
            history_kind_valid,
            relative_pos_diff,
            normal_cone_min,
            max_relative_depth_delta);

    float history_lum_before_clip = luminance(history);
    history = temporal_clamp_history_ycocg(history, min_color, max_color, lum_sigma);
    float history_lum_after_clip = luminance(history);
    float lum_delta = abs(history_lum_before_clip - center_lum) / (max(center_lum, history_lum_before_clip) + 0.02);
    float clipped_lum_delta = abs(history_lum_before_clip - history_lum_after_clip) / (history_lum_before_clip + 0.02);
    float neighborhood_lum_delta = abs(history_lum_before_clip - lum_mean) / (lum_mean + lum_sigma + 0.02);
    float reactive_mask = temporal_reactive_weight(lum_delta, clipped_lum_delta, neighborhood_lum_delta);

    float confidence = temporal_variance_confidence(center_var, 10.0);
    float motion_confidence = temporal_motion_confidence(velocity_pixels, 24.0, 0.35);
    float specular_rejection = 1.0 - reactive_mask * mix(0.65, 0.95, confidence);
    float frame_blend = params.reset_history != 0u ? 0.0 : clamp(float(params.frame_count - 1u) / 30.0, 0.0, 1.0);
    float history_weight = temporal_history_weight(confidence, disocclusion_confidence, motion_confidence, reactive_mask, frame_blend);
    float denoiser_rejection = 1.0 - clamp(disocclusion_confidence * motion_confidence * specular_rejection, 0.0, 1.0);

    vec3 debug_color = filtered_color;
    PathDataRecord path_data = path_data_buffer[pixel_index];
    if (params.debug_view == 1u) {
        debug_color = vec3(center_var / 4.0);
    } else if (params.debug_view == 2u) {
        debug_color = center_normal * 0.5 + 0.5;
    } else if (params.debug_view == 3u) {
        debug_color = vec3(disocclusion_confidence);
    } else if (params.debug_view == 4u) {
        debug_color = vec3(denoiser_rejection, 1.0 - denoiser_rejection, 0.0);
    } else if (params.debug_view == 28u) {
        vec2 visual_velocity = clamp(velocity_pixels / 32.0, vec2(-1.0), vec2(1.0));
        debug_color = vec3(visual_velocity * 0.5 + vec2(0.5), clamp(length(velocity_pixels) / 32.0, 0.0, 1.0));
    } else if (params.debug_view == 33u) {
        debug_color = vec3(reactive_mask, 1.0 - reactive_mask, 0.0);
    } else if (params.debug_view == 34u) {
        debug_color = vec3(history_weight);
    } else if (params.debug_view == 47u) {
        debug_color = path_data.direct_diffuse.rgb;
    } else if (params.debug_view == 48u) {
        debug_color = path_data.direct_specular.rgb;
    } else if (params.debug_view == 49u) {
        debug_color = path_data.indirect_diffuse.rgb;
    } else if (params.debug_view == 50u) {
        debug_color = path_data.indirect_specular.rgb;
    } else if (params.debug_view == 51u) {
        debug_color = path_data.albedo_roughness_hit_confidence.rgb;
    } else if (params.debug_view == 52u) {
        debug_color = vec3(
            clamp(path_data.albedo_roughness_hit_confidence.w, 0.0, 1.0),
            clamp(log2(path_data.direct_specular.a + 1.0) / 10.0, 0.0, 1.0),
            clamp(path_data.indirect_diffuse.a, 0.0, 1.0));
    } else if (params.debug_view == 53u) {
        debug_color = vec3(float(adaptive_kernel_radius) / 2.0);
    }

    vec3 denoised = params.debug_view == 0u ? mix(filtered_color, history, history_weight) : debug_color;
    imageStore(output_denoised, coords, vec4(denoised, 1.0));
}
